# ─────────────────────────────────────────────────────────────────────────────
# Climate & Geo-Risk Monitor — environment variables
# ทุกตัวเป็น "optional": ระบบทำงาน/ดีพลอยได้แม้ไม่ตั้งค่า (graceful degradation)
# ตั้งค่าใน Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (เก็บ time-series / risk_scores / audit / alerts) ──
# ไม่ตั้ง = ระบบยังคำนวณ/แสดงผลได้ แต่ไม่บันทึกประวัติ
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Cron security ──
# ตั้งค่านี้แล้ว Vercel Cron จะแนบ Authorization: Bearer <CRON_SECRET> อัตโนมัติ
# ไม่ตั้ง = endpoint /api/cron/* เปิดให้เรียกได้ (เหมาะกับ dev เท่านั้น)
CRON_SECRET=

# ── LINE Messaging API (แจ้งเตือน + บรีฟ) ──
# LINE Notify ถูกยกเลิกแล้ว (2025) จึงใช้ Messaging API push
# ไม่ตั้ง = ไม่ส่งแจ้งเตือน (แต่ cron ยังคำนวณ/บันทึกปกติ)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TARGET_ID=

# ── Verification Agent (LLM) ──
# ไม่ตั้ง = /api/verify ใช้ตัวตรวจแบบ heuristic แทน
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
